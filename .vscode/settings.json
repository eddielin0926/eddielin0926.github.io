{
    "files.autoSave": "onFocusChange",
    "files.exclude": {
        "**/.vscode": true,
        "**/build": true,
        "**/node_modules": true,
        "**/.docusaurus": true,
        "**/.cache-loader": true
    },
    "grammarly.files.include": [
        "**/*.txt",
        "**/*.md",
        "**/*.mdx"
    ],
    "grammarly.config.documentDomain": "academic"
}